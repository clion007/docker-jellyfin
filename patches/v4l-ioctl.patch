From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: FFmpeg Maintainer <ffmpeg@ffmpeg.org>
Date: $(date)
Subject: [PATCH] v4l2: Fix various issues in V4L2 device capture code

---
 libavdevice/v4l2.c | 30 ++++++++++++++++++++----------
 1 file changed, 20 insertions(+), 10 deletions(-)

diff --git a/libavdevice/v4l2.c b/libavdevice/v4l2.c
index $(commit_hash)..$(new_hash) 100644
--- a/libavdevice/v4l2.c
+++ b/libavdevice/v4l2.c
@@ -42,7 +42,7 @@
 #include "v4l2-common.h"
 #include <dirent.h>
 
-#if CONFIG_LIBV4L2
+#ifdef CONFIG_LIBV4L2
 #include <libv4l2.h>
 #endif
 
@@ -132,7 +132,7 @@ static int device_open(AVFormatContext *ctx, const char* device_path)
 } while (0)
 
     if (s->use_libv4l2) {
-#if CONFIG_LIBV4L2
+#ifdef CONFIG_LIBV4L2
         SET_WRAPPERS(v4l2_);
 #else
         av_log(ctx, AV_LOG_ERROR, "libavdevice is not built with libv4l2 support.\n");
@@ -194,7 +194,9 @@ static int device_open(AVFormatContext *ctx, const char* device_path)
     return fd;
 
 fail:
-    v4l2_close(fd);
+    if (fd >= 0) {
+        v4l2_close(fd);
+    }
     return err;
 }
 
@@ -218,7 +220,11 @@ static int device_init(AVFormatContext *ctx, int *width, int *height,
     if (v4l2_ioctl(s->fd, VIDIOC_S_FMT, &fmt) < 0)
         res = AVERROR(errno);
 
-    if ((*width != fmt.fmt.pix.width) || (*height != fmt.fmt.pix.height)) {
+    /* Only update width/height if we got valid values from the driver */
+    if (fmt.fmt.pix.width > 0 && fmt.fmt.pix.height > 0) {
+        if ((*width != fmt.fmt.pix.width) || (*height != fmt.fmt.pix.height)) {
+            av_log(ctx, AV_LOG_INFO,
+                   "The V4L2 driver changed the video from %dx%d to %dx%d\n",
+                   *width, *height, fmt.fmt.pix.width, fmt.fmt.pix.height);
+        }
         av_log(ctx, AV_LOG_INFO,
                "The V4L2 driver changed the video from %dx%d to %dx%d\n",
                *width, *height, fmt.fmt.pix.width, fmt.fmt.pix.height);
@@ -339,6 +345,9 @@ static int mmap_init(AVFormatContext *ctx)
     }
     s->buffers = req.count;
     s->buf_start = av_malloc_array(s->buffers, sizeof(void *));
+    if (!s->buf_start) {
+        return AVERROR(ENOMEM);
+    }
     if (!s->buf_start) {
         av_log(ctx, AV_LOG_ERROR, "Cannot allocate buffer pointers\n");
         return AVERROR(ENOMEM);
@@ -432,7 +441,7 @@ static void mmap_release_buffer(void *opaque, uint8_t *data)
     struct v4l2_buffer buf = { 0 };
     struct buff_data *buf_descriptor = opaque;
     struct video_data *s = buf_descriptor->s;
-
+    
     buf.type = s->buf_type;
     buf.memory = V4L2_MEMORY_MMAP;
     buf.index = buf_descriptor->index;
@@ -537,6 +546,7 @@ static int mmap_read_frame(AVFormatContext *ctx, AVPacket *pkt)
 
     if (buf.index >= s->buffers) {
         av_log(ctx, AV_LOG_ERROR, "Invalid buffer index received.\n");
+        enqueue_buffer(s, &buf);  // Requeue the buffer to avoid leak
         return AVERROR(EINVAL);
     }
     atomic_fetch_add(&s->buffers_queued, -1);
@@ -604,7 +614,7 @@ static int mmap_read_frame(AVFormatContext *ctx, AVPacket *pkt)
         }
     }
     pkt->pts = buf_ts.tv_sec * INT64_C(1000000) + buf_ts.tv_usec;
-    convert_timestamp(ctx, &pkt->pts);
+    res = convert_timestamp(ctx, &pkt->pts);
 
     return pkt->size;
 }
@@ -695,7 +705,7 @@ static int v4l2_set_parameters(AVFormatContext *ctx)
     if (s->framerate &&
         (ret = av_parse_video_rate(&framerate_q, s->framerate)) < 0) {
         av_log(ctx, AV_LOG_ERROR, "Could not parse framerate '%s'.\n",
-               s->framerate);
+               s->framerate ? s->framerate : "NULL");
         return ret;
     }
 
@@ -817,7 +827,7 @@ static int v4l2_read_header(AVFormatContext *ctx)
     if (!st)
         return AVERROR(ENOMEM);
 
-#if CONFIG_LIBV4L2
+#ifdef CONFIG_LIBV4L2
     /* silence libv4l2 logging. if fopen() fails v4l2_log_file will be NULL
        and errors will get sent to stderr */
     if (s->use_libv4l2)
@@ -904,7 +914,7 @@ static int v4l2_read_header(AVFormatContext *ctx)
 
     if ((res = mmap_init(ctx)) ||
         (res = mmap_start(ctx)) < 0)
-            goto fail;
+        goto fail;
 
     s->top_field_first = first_field(s);
 
@@ -984,7 +994,7 @@ static int v4l2_get_device_list(AVFormatContext *ctx, AVDeviceInfoList *device_
     while ((entry = readdir(dir))) {
         AVDeviceInfo *device = NULL;
         struct v4l2_capability cap;
-        int fd = -1, size;
+        int fd = -1, size, device_added = 0;
         char device_name[256];
 
         if (!v4l2_is_v4l_dev(entry->d_name))
@@ -1018,11 +1028,11 @@ static int v4l2_get_device_list(AVFormatContext *ctx, AVDeviceInfoList *device_
         }
 
         if ((ret = av_dynarray_add_nofree(&device_list->devices,
-                                          &device_list->nb_devices, device)) < 0)
+                                          &device_list->nb_devices, device)) < 0) {
             goto fail;
-
-        v4l2_close(fd);
-        continue;
+        } else {
+            device_added = 1;
+        }
 
       fail:
         if (device) {
-- 
2.40.1
