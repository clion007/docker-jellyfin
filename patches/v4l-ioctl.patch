+/* 包装函数，用于将 unsigned long int 转换为 int 以匹配系统 ioctl 签名 */
+static int sys_ioctl_wrapper_func(int fd, unsigned long int request, ...)
+{
+    struct video_data *s = (struct video_data *)av_get_current_context();
+    va_list ap;
+    void *arg;
+    int ret;
+    
+    va_start(ap, request);
+    arg = va_arg(ap, void *);
+    va_end(ap);
+    
+    /* 调用系统 ioctl，将 unsigned long int 转换为 int */
+    ret = ((int (*)(int, int, ...))s->ioctl_func)(fd, (int)request, arg);
+    return ret;
+}
