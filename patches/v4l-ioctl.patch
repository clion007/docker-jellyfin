+/* 包装函数，用于将 unsigned long int 转换为 int 以匹配系统 ioctl 签名 */
+static int sys_ioctl_wrapper(int fd, unsigned long int request, ...)
+{
+    va_list ap;
+    void *arg;
+    va_start(ap, request);
+    arg = va_arg(ap, void *);
+    va_end(ap);
+    
+    return ioctl(fd, (int)request, arg);
+}
