+/* Wrapper for system ioctl to match V4L2 API signature */
+static int sys_ioctl_wrapper(int fd, unsigned long int request, ...)
+{
+    va_list ap;
+    void *arg;
+    int res;
+    va_start(ap, request);
+    arg = va_arg(ap, void *);
+    va_end(ap);
+    res = ioctl(fd, (int)request, arg);
+    return res;
+}
